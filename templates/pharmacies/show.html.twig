{% extends 'base.html.twig' %}

{% block title %}Pharmacies{% endblock %}

{% block body %}
    <h1>Pharmacies</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ pharmacy.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ pharmacy.nom }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ pharmacy.adresse }}</td>
            </tr>
            <tr>
                <th>Telephone</th>
                <td>{{ pharmacy.telephone }}</td>
            </tr>
            <tr>
                <th>Latitude</th>
                <td>{{ pharmacy.latitude }}</td>
            </tr>
            <tr>
                <th>Longitude</th>
                <td>{{ pharmacy.longitude }}</td>
            </tr>
            <tr>
                <th>HoraireGarde</th>
                <td>{{ pharmacy.horaireGarde ? pharmacy.horaireGarde|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>GardeAujourdhui</th>
                <td>{{ pharmacy.gardeAujourdhui ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ pharmacy.createdAt ? pharmacy.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_pharmacies_index') }}">back to list</a>

    <a href="{{ path('app_pharmacies_edit', {'id': pharmacy.id}) }}">edit</a>

    {{ include('pharmacies/_delete_form.html.twig') }}
{% endblock %}
