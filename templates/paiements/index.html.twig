{% extends 'base.html.twig' %}

{% block title %}Paiements index{% endblock %}

{% block body %}
    <h1>Paiements index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Montant</th>
                <th>MethodePaiement</th>
                <th>Statut</th>
                <th>DatePaiement</th>
                <th>ReferenceTransaction</th>
                <th>DateConfirmation</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for paiement in paiements %}
            <tr>
                <td>{{ paiement.id }}</td>
                <td>{{ paiement.montant }}</td>
                <td>{{ paiement.methodePaiement }}</td>
                <td>{{ paiement.statut }}</td>
                <td>{{ paiement.datePaiement ? paiement.datePaiement|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ paiement.referenceTransaction }}</td>
                <td>{{ paiement.dateConfirmation ? paiement.dateConfirmation|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_paiements_show', {'id': paiement.id}) }}">show</a>
                    <a href="{{ path('app_paiements_edit', {'id': paiement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_paiements_new') }}">Create new</a>
{% endblock %}
